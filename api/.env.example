# Application Configuration
BASE_URL=http://localhost:4000
APP_URL=http://localhost:8080
PORT=4000
# Production example:
# BASE_URL=https://smartfurnish.ir
# APP_URL=https://smartfurnish.ir
# PORT=5801
API_PREFIX=api/v1
NODE_ENV=development

# Database Configuration
MONGODB_URI=mongodb://localhost:27017
MONGODB_DATABASE=smart-furnish

# JWT Configuration — generate with: openssl rand -base64 48
JWT_SECRET=replace-with-openssl-rand-base64-48
JWT_EXPIRES_IN=24h

# Captcha Configuration
CAPTCHA_ENABLED=true
CAPTCHA_TTL_SECONDS=120
CAPTCHA_MAX_ATTEMPTS=5

# Logging Configuration
LOG_LEVEL=debug
LOG_FILE=logs/app.log

# Rate Limiting
RATE_LIMIT_TTL=60
RATE_LIMIT_LIMIT=100

# Max HTTP request body size in bytes (default 50MB; applies to file uploads and JSON payloads)
# MAX_REQUEST_SIZE=52428800

# GraphQL Configuration
GRAPHQL_PLAYGROUND=true
GRAPHQL_INTROSPECTION=true

# Web Push (VAPID) — generate with: npx web-push generate-vapid-keys
# VAPID_SUBJECT should be a mailto: or https: contact URI for your app.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@smartfurnish.ir

# Firebase Cloud Messaging (native Android APK push + launcher badge sync)
# Create a Firebase project, add Android app `smartfurnish.app`, download google-services.json
# for android/app/, and create a service account with Firebase Cloud Messaging Admin.
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
# Use literal \n for newlines when storing the private key in .env
FIREBASE_PRIVATE_KEY=

# MinIO Configuration
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=admin
MINIO_SECRET_KEY=your-minio-root-password
MINIO_BUCKET=smart-furnish

# Remote dev option: you can use the Console URL; backend maps it to S3 API automatically.
# MINIO_ENDPOINT=https://minio.smartfurnish.ir
# MINIO_PORT=443
# MINIO_USE_SSL=true
