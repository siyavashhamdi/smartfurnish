{
  "name": "smart-furnish-api",
  "version": "1.0.0",
  "description": "Professional NestJS API for Smart Furnish Application",
  "author": "Smart Furnish Team",
  "private": true,
  "license": "MIT",
  "scripts": {
    "prebuild": "node ../scripts/generate-build-versions.mjs",
    "build": "NODE_OPTIONS=--max-old-space-size=768 nest build",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:write": "prettier --write \"src/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:dev:transpile": "npx ts-node-dev --respawn --transpile-only --poll -r tsconfig-paths/register src/main.ts",
    "start:dev:fast": "npx ts-node-dev --respawn --transpile-only --poll -r dotenv/config -r tsconfig-paths/register src/main.ts",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "kill:port": "lsof -ti:3000 | xargs kill -9 2>/dev/null || echo \"No process found on port 3000\"",
    "seed:products": "tsx -r tsconfig-paths/register src/scripts/seed-real-products.ts",
    "seed:coupons": "tsx -r tsconfig-paths/register src/scripts/seed-real-coupons.ts",
    "seed:notifications": "tsx -r tsconfig-paths/register src/scripts/seed-notifications.ts",
    "seed:product-reviews": "tsx -r tsconfig-paths/register src/scripts/seed-product-reviews.ts",
    "migrate:product-prices": "tsx -r tsconfig-paths/register src/scripts/migrate-product-price-to-colors.ts",
    "migrate:product-discounts": "tsx -r tsconfig-paths/register src/scripts/migrate-product-discount-to-colors.ts",
    "migrate:file-thumbnails": "tsx -r tsconfig-paths/register src/scripts/backfill-file-thumbnails.ts"
  },
  "dependencies": {
    "@apollo/server": "^4.9.5",
    "@nestjs/apollo": "^12.0.11",
    "@nestjs/common": "^10.0.0",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^10.0.0",
    "@nestjs/graphql": "^12.0.11",
    "@nestjs/jwt": "^11.0.1",
    "@nestjs/mongoose": "^10.0.2",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^10.0.0",
    "@nestjs/schedule": "^6.0.1",
    "@nestjs/swagger": "^7.4.2",
    "axios": "^1.13.2",
    "bcrypt": "^6.0.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.0",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "firebase-admin": "^14.1.0",
    "form-data": "^4.0.4",
    "graphql": "^16.12.0",
    "graphql-subscriptions": "^2.0.0",
    "graphql-type-json": "^0.3.2",
    "helmet": "^7.2.0",
    "joi": "^17.13.3",
    "lodash": "^4.17.21",
    "minio": "^8.0.7",
    "mongoose": "^8.0.3",
    "nest-winston": "^1.9.4",
    "nodemailer": "^9.0.0",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "reflect-metadata": "^0.1.14",
    "rxjs": "^7.8.1",
    "sharp": "^0.35.1",
    "swagger-ui-express": "^5.0.1",
    "uuid": "^13.0.0",
    "web-push": "^3.6.7",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.10",
    "@nestjs/schematics": "^10.0.0",
    "@nestjs/testing": "^10.0.0",
    "@types/axios": "^0.9.36",
    "@types/bcrypt": "^6.0.0",
    "@types/compression": "^1.7.5",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.25",
    "@types/jest": "^29.5.14",
    "@types/lodash": "^4.17.20",
    "@types/node": "^20.19.24",
    "@types/nodemailer": "^8.0.1",
    "@types/passport-jwt": "^4.0.1",
    "@types/supertest": "^2.0.16",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^9.1.2",
    "eslint-plugin-prettier": "^5.0.0",
    "jest": "^29.7.0",
    "prettier": "^3.0.0",
    "source-map-support": "^0.5.21",
    "supertest": "^6.3.4",
    "ts-jest": "^29.1.0",
    "ts-loader": "^9.4.3",
    "ts-node": "^10.9.1",
    "ts-node-dev": "^2.0.0",
    "tsconfig-paths": "^4.2.0",
    "tsx": "^4.20.6",
    "typescript": "^5.1.3"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  }
}
