{
  "name": "smart-furnish",
  "private": true,
  "scripts": {
    "build": "npm run build --prefix api",
    "build:all": "npm run build --prefix api && npm run build:app",
    "build:app": "npm run typecheck --prefix app && npm run build --prefix app",
    "start": "pm2 start ecosystem.config.cjs",
    "stop": "pm2 stop ecosystem.config.cjs",
    "restart": "pm2 restart ecosystem.config.cjs",
    "logs": "pm2 logs",
    "deploy": "bash scripts/deploy.sh",
    "publish:app": "bash scripts/publish-app.sh"
  }
}
