{
    "name": "smart-furnish",
    "version": "1.0.0",
    "description": "Smart Furnish administration dashboard with RTL support",
    "private": true,
    "author": "Siya",
    "license": "UNLICENSED",
    "licenseText": "Proprietary - All rights reserved. This software is not free and is protected by copyright laws.",
    "keywords": [
        "smart-furnish",
        "streaming",
        "dashboard",
        "content-management"
    ],
    "scripts": {
        "dev": "vite",
        "dev:no-refresh": "VITE_NO_REFRESH=true VITE_PWA_DEV=false vite",
        "build": "vite build",
        "prebuild": "node ../scripts/generate-build-versions.mjs && npm run generate:pwa-icons && npm run generate:sitemap",
        "generate:pwa-icons": "node scripts/generate-pwa-icons.mjs",
        "generate:sitemap": "node scripts/generate-sitemap.mjs",
        "typecheck": "tsc --noEmit",
        "preview": "vite preview",
        "start": "serve dist --no-clipboard --single --listen tcp://0.0.0.0:${PORT:-5800}",
        "lint": "eslint . --report-unused-disable-directives --max-warnings 0",
        "lint:fix": "eslint . --fix",
        "format:write": "prettier --write \"**/*.{ts,tsx,js,jsx,json,css,md}\" --ignore-path .gitignore",
        "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,css,md}\" --ignore-path .gitignore",
        "type-check": "tsc --noEmit",
        "clean": "rm -rf dist node_modules/.vite",
        "cap:sync": "cap sync android",
        "cap:open": "cap open android",
        "generate:gql-types": "graphql-codegen --config gql-codegen.ts && rm -f src/lib/graphql/generated/gql.ts && echo 'export * from \"./graphql\";' > src/lib/graphql/generated/index.ts && prettier --write src/lib/graphql/generated/graphql.ts",
        "generate:gql-types:watch": "graphql-codegen --config gql-codegen.ts --watch"
    },
    "dependencies": {
        "@apollo/client": "^4.0.9",
        "@capacitor/android": "^7.6.7",
        "@capacitor/app": "^7.1.2",
        "@capacitor/cli": "^7.6.7",
        "@capacitor/core": "^7.6.7",
        "@capacitor/network": "^7.0.4",
        "@capacitor/push-notifications": "^7.0.6",
        "@capacitor/splash-screen": "^7.0.5",
        "@capacitor/status-bar": "^7.0.6",
        "@emotion/cache": "^11.11.0",
        "@emotion/react": "^11.11.1",
        "@emotion/styled": "^11.11.0",
        "@graphql-codegen/cli": "^6.1.0",
        "@graphql-codegen/client-preset": "^5.2.1",
        "@graphql-codegen/typescript": "^5.0.6",
        "@graphql-codegen/typescript-operations": "^5.0.6",
        "@graphql-codegen/typescript-react-apollo": "^4.3.3",
        "@mui/icons-material": "^5.14.19",
        "@mui/material": "^5.14.20",
        "@tanstack/react-table": "^8.21.3",
        "browser-image-compression": "^2.0.2",
        "dayjs": "^1.11.19",
        "graphql": "^16.12.0",
        "graphql-ws": "^6.0.8",
        "i18next": "^25.7.1",
        "i18next-browser-languagedetector": "^8.2.0",
        "react": "^18.2.0",
        "react-date-object": "^2.1.9",
        "react-dom": "^18.2.0",
        "react-i18next": "^16.3.5",
        "react-multi-date-picker": "^4.5.2",
        "react-router-dom": "^6.20.1",
        "serve": "^14.2.4",
        "sql.js": "^1.12.0",
        "stylis": "^4.3.6",
        "stylis-plugin-rtl": "^2.1.1"
    },
    "devDependencies": {
        "@types/node": "^24.10.1",
        "@types/react": "^18.2.43",
        "@types/react-dom": "^18.2.17",
        "@typescript-eslint/eslint-plugin": "^8.0.0",
        "@typescript-eslint/parser": "^8.0.0",
        "@vitejs/plugin-react": "^4.2.1",
        "eslint": "^9.0.0",
        "eslint-plugin-react": "^7.37.0",
        "eslint-plugin-react-hooks": "^5.0.0",
        "eslint-plugin-react-refresh": "^0.4.16",
        "jiti": "^2.0.0",
        "prettier": "^3.1.1",
        "sass": "^1.94.2",
        "sharp": "^0.35.2",
        "typescript": "^5.3.2",
        "vite": "^7.2.6",
        "vite-plugin-pwa": "^1.3.0",
        "workbox-core": "^7.4.1",
        "workbox-precaching": "^7.4.1",
        "workbox-routing": "^7.4.1"
    }
}
